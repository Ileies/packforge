# --- Produktion (öffentliche Instanz nur unter packforge.ileies.de) ---
# SvelteKit adapter-node: öffentliche Basis-URL (ohne Pfad-Suffix)
# ORIGIN=https://packforge.ileies.de
# Microsoft Entra: Redirect-URI muss in der App-Registrierung exakt so eingetragen sein
# AZURE_REDIRECT_URI=https://packforge.ileies.de/login

# --- Optional: Azure / Entra (Produktion) ---
# Bei NODE_ENV=production sind AZURE_CLIENT_ID, AZURE_TENANT_ID, AZURE_REDIRECT_URI Pflicht
# (Redirect: öffentliche https-URL, kein localhost), sofern nicht explizit:
# AUTH_ENTRA_OPTIONAL_IN_PRODUCTION=true   # nur bewusst für rein interne / abgeschirmte Instanzen
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=

# Öffentliche Portfolio-Demo: App ohne Login nutzbar, eingeschränkte Gast-Rechte; Vollzugrang nur per Anmeldung (Einladung).
# Client + Server: exakt "true" zum Aktivieren.
# PUBLIC_OPEN_PORTFOLIO_MODE=false

# Session-JWT (setzen für echte Umgebungen)
JWT_SECRET=bitte-sicheren-wert-setzen

# Lokaler Login ohne Microsoft (POST /api/auth/dev-login) — „Als Entwickler anmelden“ auf /login
# — Nur aktiv bei explizitem ALLOW_DEV_LOGIN=true (oder 1 / yes, case-insensitive). Ohne diese Variable: Dev-Login aus.
# — ALLOW_DEV_LOGIN=false: explizit aus
#
# Sicherheit: Mit ALLOW_DEV_LOGIN=true verlangt assertValidPrivateEnv() IMMER ein JWT_SECRET mit mindestens 32 Zeichen
# (kein Platzhalter dev-secret-change-in-production).
#
# Production ohne Entra: Dev-Login ist erlaubt, wenn gleichzeitig AUTH_ENTRA_OPTIONAL_IN_PRODUCTION=true und
# DEV_LOGIN_PASSWORD mindestens 16 Zeichen (Admin-Zugang ohne Microsoft — Passwort geheim halten).
# Ohne Entra-Optional-Flag bleibt Dev-Login in production gesperrt.
# ALLOW_DEV_LOGIN=true
# DEV_LOGIN_PASSWORD=   # in production mit Dev-Login: Pflicht, ≥16 Zeichen; lokal empfohlen sobald die Instanz nicht nur auf localhost lauscht

# KI — optional per Env; fehlen beide, können API-Schlüssel in der UI gesetzt werden (Einstellungen). In der UI
# gesetzte Schlüssel werden in der Haupt-DB verschlüsselt gespeichert (AES-256-GCM, abgeleitet von JWT_SECRET);
# Werte aus der Umgebung haben Vorrang vor der DB.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Pfade (normalerweise nicht nötig — alles unter ./data)
# DATA_ROOT=
# MAIN_DB_PATH=file:./data/database/packforge.db
# PACKAGES_DB_PATH=file:./data/database/packages.db
# UPLOADS_DIR=   # optional; sonst unter DATA_ROOT

# Session-/CSRF-Cookies: ohne HTTPS (z. B. vite preview auf http) Set-Cookie mit Secure=false erzwingen:
# COOKIE_INSECURE=1

# HTTP-Zugriffslogs als eine JSON-Zeile pro Request; stdout spiegeln abschalten: LOG_STDOUT=0
# Dateien: standardmäßig unter <DATA_ROOT>/logs (http-access.log, audit.log), Rotation bei Größe, alte Dateien nach Retention
# LOG_FILE_ENABLED=false   # nur stdout (keine Logdateien)
# LOG_DIR=                 # optional: anderes Verzeichnis statt <DATA_ROOT>/logs
# LOG_MAX_BYTES=52428800   # Rotation der aktiven Datei (Standard 50 MiB)
# LOG_RETENTION_DAYS_HTTP=90    # gelöscht: rotierte http-access.<timestamp>.log älter als … Tage
# LOG_RETENTION_DAYS_AUDIT=365  # gelöscht: rotierte audit.<timestamp>.log älter als … Tage
# LOG_STDOUT=0             # bei Dateilog: keine JSON-Zeilen mehr auf stdout (nur Datei)
# LOG_HTTP_ACCESS=0        # HTTP-Zugriffslog komplett aus (weder stdout noch Datei)
# LOG_LEVEL=info           # Server-Konsole: error | warn | info | debug (Standard: production=info, test=error, development=debug)
# PUBLIC_LOG_VERBOSE=1   # Browser: zusätzliche clientLog-Warnungen auch außerhalb dev (1 / true / yes)

# Upload: maximale Größe pro Datei (Bytes), Standard 524288000 (500 MiB)
# MAX_UPLOAD_BYTES=524288000

# Öffentliche Rechtsseiten: optional Weiterleitung statt eingebetteter Standardtexte unter /impressum, /datenschutz, /nutzungsbedingungen
# LEGAL_IMPRESSUM_URL=
# LEGAL_PRIVACY_URL=
# LEGAL_TERMS_URL=

# Inline-Hilfe in der App-Shell (Sidebar): nur http(s)-URLs. Entweder …
# HELP_DOCUMENTATION_URL=
# HELP_WIKI_URL=
# HELP_CONFLUENCE_URL=
# … oder ein JSON-Array (hat Vorrang), z. B. [{"label":"Handbuch","href":"https://wiki.firma/handbuch"}]
# HELP_LINKS_JSON=

# KI: optionales Tageslimit (UTC, zählt erfolgreiche Anfragen) — zusätzlich zu RATE_LIMIT_AI_*
# AI_DAILY_MAX_REQUESTS=

# Rate Limiting (In-Memory pro Prozess): Login-POST, /api/ai/*, POST /api/software & /api/formfields/import — abschalten z. B. für Tests: RATE_LIMIT_DISABLED=true
# RATE_LIMIT_LOGIN_MAX=20
# RATE_LIMIT_LOGIN_WINDOW_SEC=60
# RATE_LIMIT_AI_MAX=90
# RATE_LIMIT_AI_WINDOW_SEC=60
# RATE_LIMIT_API_WRITE_MAX=60
# RATE_LIMIT_API_WRITE_WINDOW_SEC=60
# RATE_LIMIT_DISABLED=true
