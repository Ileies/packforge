{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"entry": [
		"src/hooks.server.ts",
		"svelte.config.js",
		"vite.config.ts",
		"src/routes/**/*/+{page,server,layout,error}{,@*}.{ts,svelte}"
	],
	"project": ["src/**/*.{ts,svelte}", "tests/**/*.ts", "e2e/**/*.ts"],
	"ignore": [
